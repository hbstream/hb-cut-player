       <item>
        <layout class="QVBoxLayout" name="cutFormColumn">
         <property name="spacing"><number>8</number></property>
         <item>
          <widget class="QLabel" name="labelCutSection">
           <property name="text">
            <string>视频剪辑</string>
           </property>
           <property name="objectName">
            <string notr="true">labelCutSection</string>
           </property>
          </widget>
         </item>
         <item>
          <layout class="QGridLayout" name="cutFormLayout">
           <property name="horizontalSpacing"><number>8</number></property>
           <property name="verticalSpacing"><number>6</number></property>
           <item row="0" column="0">
            <widget class="QPushButton" name="btnSetCutStart">
             <property name="text">
              <string>设定开始</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QLineEdit" name="editCutTimeBeg">
             <property name="placeholderText">
              <string>HH:mm:ss</string>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QPushButton" name="btnSetCutStop">
             <property name="text">
              <string>设定结束</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QLineEdit" name="editCutTimeEnd">
             <property name="placeholderText">
              <string>HH:mm:ss</string>
             </property>
            </widget>
           </item>
           <item row="2" column="0" colspan="2">
            <widget class="QPushButton" name="btnAddCutTask">
             <property name="text">
              <string>添加剪切任务</string>
             </property>
             <property name="toolTip">
              <string>把当前 [设定开始, 设定结束] 区间作为新任务加入下面的列表</string>
             </property>
            </widget>
           </item>
          </layout>
         </item>
         <item>
          <spacer name="cutFormBottomSpacer">
