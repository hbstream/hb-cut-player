<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>XAVIPlayerClass</class>
 <widget class="QMainWindow" name="XAVIPlayerClass">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1100</width>
    <height>900</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>HB Cut Player</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QMainWindow,
QWidget#centralWidget {
    background-color: #15171b;
    color: #e6e6e6;
}

/* 上半区：播放器，整体偏黑，紧贴视频画面 */
QFrame#playerCard {
    background-color: #15171b;
    border: none;
}
QFrame#frameVideo {
    background-color: #000000;
    border: none;
}
QFrame#bottomBar {
    background-color: #1b1e23;
    border-top: 1px solid #2c3138;
}

/* 下半区：剪切 / 合并工作区，使用更亮的灰，作为独立的“卡片” */
QFrame#workCard {
    background-color: #232830;
    border: 1px solid #2f3640;
    border-radius: 6px;
}

QTabWidget::pane,
QWidget#tabCut,
QWidget#tabMerge {
    background-color: #232830;
    border: none;
}

QLabel {
    color: #e6e6e6;
}

QLabel#labelTime {
    color: #d6d6d6;
    font-family: Consolas, &quot;DejaVu Sans Mono&quot;, monospace;
    font-size: 12pt;
    padding: 0 8px;
}

QLabel#labelRate {
    color: #f7c873;
    font-weight: bold;
    padding: 0 8px;
}

QLabel#labelSpeedGroup {
    color: #8b95a3;
    font-size: 9pt;
    padding: 0 6px 0 10px;
    letter-spacing: 1px;
}

QLabel#labelCutSection {
    color: #d8dee9;
    font-size: 11pt;
    font-weight: 600;
    padding: 0 0 4px 0;
}

QPushButton {
    background-color: #2f343c;
    color: #e6e6e6;
    border: 1px solid #3a4049;
    border-radius: 4px;
    padding: 6px 14px;
    min-width: 56px;
}
QPushButton:hover { background-color: #3a4049; }
QPushButton:pressed { background-color: #4a5260; }
QPushButton:disabled { color: #6a6a6a; background-color: #262a31; }

/* 透明圆形播放控制按钮，纯图标风格 */
QPushButton[transportRole="true"] {
    background-color: transparent;
    border: none;
    border-radius: 18px;
    min-width: 36px;
    max-width: 36px;
    min-height: 36px;
    max-height: 36px;
    padding: 0;
    font-size: 16pt;
    color: #d8dee9;
}
QPushButton[transportRole="true"]:hover {
    background-color: #2f343c;
    color: #ffffff;
}
QPushButton[transportRole="true"]:pressed { background-color: #3a4049; }

QPushButton[primaryTransport="true"] {
    background-color: #1f6feb;
    color: #ffffff;
}
QPushButton[primaryTransport="true"]:hover  { background-color: #2f7df6; }
QPushButton[primaryTransport="true"]:pressed { background-color: #1657c3; }

QPushButton#btnPrimary {
    background-color: #1f6feb;
    border-color: #1f6feb;
    color: #ffffff;
    font-weight: bold;
}
QPushButton#btnPrimary:hover { background-color: #2f7df6; }
QPushButton#btnPrimary:pressed { background-color: #1657c3; }

QPushButton#btnDanger {
    background-color: #b63a3a;
    border-color: #b63a3a;
    color: #ffffff;
}
QPushButton#btnDanger:hover { background-color: #c84747; }

QLineEdit {
    background-color: #1c1f24;
    border: 1px solid #3a4049;
    border-radius: 3px;
    padding: 4px 6px;
    color: #e6e6e6;
    selection-background-color: #1f6feb;
}

QSlider::groove:horizontal {
    height: 6px;
    background: #1c1f24;
    border-radius: 3px;
}
QSlider::sub-page:horizontal {
    background: #1f6feb;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #ffffff;
    border: 1px solid #1f6feb;
    width: 12px;
    margin: -4px 0;
    border-radius: 6px;
}
QSlider::handle:horizontal:hover { background: #f0f7ff; }

QTabWidget::pane { top: -1px; }
QTabBar::tab {
    background: #262a31;
    color: #c0c0c0;
    padding: 6px 18px;
    border: 1px solid #2c3138;
    border-bottom: none;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}
QTabBar::tab:selected {
    background: #1f6feb;
    color: #ffffff;
}
QTabBar::tab:hover:!selected { background: #2f343c; }

QTableWidget {
    background-color: #1c1f24;
    alternate-background-color: #232730;
    color: #e6e6e6;
    gridline-color: #2c3138;
    border: 1px solid #2c3138;
    selection-background-color: #1f6feb;
    selection-color: #ffffff;
}
QHeaderView::section {
    background-color: #2f343c;
    color: #e6e6e6;
    padding: 4px;
    border: none;
    border-right: 1px solid #1c1f24;
}

QToolTip {
    background-color: #2b303a;
    color: #f0f0f0;
    border: 1px solid #1f6feb;
    padding: 4px 8px;
    border-radius: 3px;
    font-size: 9pt;
}
</string>
