   </layout>
  </widget>
 </widget>
 <layoutdefault spacing="6" margin="11"/>
 <resources>
  <include location="XAVIPlayer.qrc"/>
 </resources>
 <connections>
  <connection>
   <sender>btnOpen</sender>
   <signal>clicked()</signal>
   <receiver>XAVIPlayerClass</receiver>
   <slot>onBtnOpenClick()</slot>
   <hints>
    <hint type="sourcelabel"><x>0</x><y>0</y></hint>
    <hint type="destinationlabel"><x>0</x><y>0</y></hint>
   </hints>
  </connection>
  <connection>
   <sender>btnStart</sender>
   <signal>clicked()</signal>
   <receiver>XAVIPlayerClass</receiver>
   <slot>onBtnStartClick()</slot>
   <hints>
    <hint type="sourcelabel"><x>0</x><y>0</y></hint>
    <hint type="destinationlabel"><x>0</x><y>0</y></hint>
   </hints>
  </connection>
  <connection>
   <sender>btnStop</sender>
   <signal>clicked()</signal>
